rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /*
     * Public multipage site:
     * - Allow anonymous reads only for explicit public-safe mirror docs.
     * - Several editorial sections are live-first via public_* mirrors.
     * - Bundled JSON remains fallback for those sections and primary only for
     *   intentionally rebuild-canonical areas such as Media.
     *
     * Internal/admin data:
     * - Admin v2 and admin v3 read/write docs under /rg/{docId}.
     * - Access is restricted to the explicit admin allowlist below.
     */
    function isAdminUser() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'rolandoguy@gmail.com';
    }
    function isPublicWebsiteDoc(docId) {
      return docId.matches('^public_(hero|bio|contact|perf)_(en|de|es|it|fr)$')
        || docId == 'public_rg_perfs'
        || docId == 'public_rg_past_perfs'
        || docId == 'public_rg_press'
        || docId == 'public_rg_press_meta'
        || docId == 'public_rg_epk_bios'
        || docId == 'public_rg_epk_photos'
        || docId == 'public_rg_public_pdfs'
        || docId.matches('^public_rep_(en|de|es|it|fr)$')
        || docId == 'public_rg_rep_cards'
        || docId.matches('^public_rg_programs_(en|de|es|it|fr)$')
        || docId.matches('^public_rg_editorial_(en|de|es|it|fr)$');
    }

    match /rg/{docId} {
      /*
       * This blocks anonymous access to internal/admin docs including:
       * - admin_v3_cases
       * - admin_v3_contacts
       * - admin_v3_calendar
       * - admin_v3_income
       * - rg_admin_contacts_followups
       * - rg_program_blueprints
       * - rg_concert_history
       * - legacy mixed admin/public documents
       *
       * Public website live docs are explicit public-safe mirrors only.
       * Internal/admin docs remain private.
       */
      allow read: if isAdminUser() || isPublicWebsiteDoc(docId);
      allow write: if isAdminUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
